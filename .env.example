# Environment configuration for AI Travel Planner
# Copy this file to .env and fill in your actual values.
# WARNING: Never commit .env to version control!

# REQUIRED: Your OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model to use (gpt-4o, gpt-4, gpt-3.5-turbo, etc.)
MODEL_NAME=gpt-4

# Google Maps API key for richer map embeds (optional)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenWeatherMap API key for weather-aware planning (optional)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Directory for ChromaDB vector store persistence
CHROMA_PERSIST_DIR=./chroma_db

# Default origin city for travel bookings
ORIGIN_CITY=Bangalore
